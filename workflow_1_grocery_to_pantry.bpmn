<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn">
                  
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_User" name="User" processRef="Process_User" />
    <bpmn:participant id="Participant_System" name="Nourish Neural Application" processRef="Process_System" />
    <!-- Cross-pool interactions -->
    <bpmn:messageFlow id="Flow_M1" sourceRef="Task_CheckOff" targetRef="Task_SendPatch" />
    <bpmn:messageFlow id="Flow_M2" sourceRef="Task_ShowToast" targetRef="End_User" />
  </bpmn:collaboration>

  <bpmn:process id="Process_User" isExecutable="false">
    <bpmn:startEvent id="Start_User" name="Review Grocery List">
      <bpmn:outgoing>Flow_U1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_CheckOff" name="Check Off Purchased Item">
      <bpmn:incoming>Flow_U1</bpmn:incoming>
    </bpmn:task>
    <bpmn:endEvent id="End_User" name="Pantry Automatically Checked-In" />
    <bpmn:sequenceFlow id="Flow_U1" sourceRef="Start_User" targetRef="Task_CheckOff" />
  </bpmn:process>

  <bpmn:process id="Process_System" isExecutable="true">
    <bpmn:laneSet id="LaneSet_System">
      <bpmn:lane id="Lane_Client" name="React 18 PWA (Client)">
        <bpmn:flowNodeRef>Task_SendPatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowToast</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_API" name="Express Backend">
        <bpmn:flowNodeRef>Task_Toggle</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Dupe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IncQty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Insert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Return</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DB" name="Supabase">
        <!-- The Data Store is drawn here, technically it is a global element but assigned to the DB lane conceptually -->
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- REACT CLIENT -->
    <bpmn:task id="Task_SendPatch" name="Send PATCH Request (Toggle)">
      <bpmn:outgoing>Flow_C1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ShowToast" name="Invalidate Cache &amp; Show Toast">
      <bpmn:incoming>Flow_C2</bpmn:incoming>
    </bpmn:task>

    <!-- EXPRESS API -->
    <bpmn:task id="Task_Toggle" name="Toggle is_checked flag">
      <bpmn:incoming>Flow_C1</bpmn:incoming>
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Dupe" name="Duplicate in Pantry?">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
      <bpmn:outgoing>Flow_A2</bpmn:outgoing>
      <bpmn:outgoing>Flow_A3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_IncQty" name="Increment Existing Quantity">
      <bpmn:incoming>Flow_A2</bpmn:incoming>
      <bpmn:outgoing>Flow_A4</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataAssoc_1">
        <bpmn:targetRef>DataStore_Supabase</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_Insert" name="Insert Newly Tracked Item">
      <bpmn:incoming>Flow_A3</bpmn:incoming>
      <bpmn:outgoing>Flow_A5</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataAssoc_2">
        <bpmn:targetRef>DataStore_Supabase</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Join">
      <bpmn:incoming>Flow_A4</bpmn:incoming>
      <bpmn:incoming>Flow_A5</bpmn:incoming>
      <bpmn:outgoing>Flow_A6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Return" name="Return Array [addedToPantry: true]">
      <bpmn:incoming>Flow_A6</bpmn:incoming>
      <bpmn:outgoing>Flow_C2</bpmn:outgoing>
    </bpmn:task>

    <!-- DATA STORE -->
    <bpmn:dataStoreReference id="DataStore_Supabase" name="pantry_items Table" />

    <!-- SEQUENCE FLOWS -->
    <bpmn:sequenceFlow id="Flow_C1" sourceRef="Task_SendPatch" targetRef="Task_Toggle" />
    <bpmn:sequenceFlow id="Flow_A1" sourceRef="Task_Toggle" targetRef="Gateway_Dupe" />
    <bpmn:sequenceFlow id="Flow_A2" name="Yes (Merge)" sourceRef="Gateway_Dupe" targetRef="Task_IncQty" />
    <bpmn:sequenceFlow id="Flow_A3" name="No (Insert)" sourceRef="Gateway_Dupe" targetRef="Task_Insert" />
    <bpmn:sequenceFlow id="Flow_A4" sourceRef="Task_IncQty" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_A5" sourceRef="Task_Insert" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_A6" sourceRef="Gateway_Join" targetRef="Task_Return" />
    <bpmn:sequenceFlow id="Flow_C2" sourceRef="Task_Return" targetRef="Task_ShowToast" />
  </bpmn:process>

  <!-- STRICT X/Y GRID LAYOUT FOR VISUAL EDITORS -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      
      <!-- POOLS -->
      <bpmndi:BPMNShape id="Participant_User_di" bpmnElement="Participant_User" isHorizontal="true">
        <dc:Bounds x="100" y="50" width="1000" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_System_di" bpmnElement="Participant_System" isHorizontal="true">
        <dc:Bounds x="100" y="250" width="1000" height="550" />
      </bpmndi:BPMNShape>

      <!-- LANES -->
      <bpmndi:BPMNShape id="Lane_Client_di" bpmnElement="Lane_Client" isHorizontal="true">
        <dc:Bounds x="130" y="250" width="970" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_API_di" bpmnElement="Lane_API" isHorizontal="true">
        <dc:Bounds x="130" y="430" width="970" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_DB_di" bpmnElement="Lane_DB" isHorizontal="true">
        <dc:Bounds x="130" y="630" width="970" height="170" />
      </bpmndi:BPMNShape>

      <!-- USER POOL ELEMENTS -->
      <bpmndi:BPMNShape id="Start_User_di" bpmnElement="Start_User">
        <dc:Bounds x="150" y="117" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckOff_di" bpmnElement="Task_CheckOff">
        <dc:Bounds x="250" y="95" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_User_di" bpmnElement="End_User">
        <dc:Bounds x="882" y="117" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- SYSTEM POOL ELEMENTS -->
      <bpmndi:BPMNShape id="Task_SendPatch_di" bpmnElement="Task_SendPatch">
        <dc:Bounds x="250" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ShowToast_di" bpmnElement="Task_ShowToast">
        <dc:Bounds x="850" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Task_Toggle_di" bpmnElement="Task_Toggle">
        <dc:Bounds x="250" y="490" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Dupe_di" bpmnElement="Gateway_Dupe" isMarkerVisible="true">
        <dc:Bounds x="400" y="505" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IncQty_di" bpmnElement="Task_IncQty">
        <dc:Bounds x="500" y="440" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Insert_di" bpmnElement="Task_Insert">
        <dc:Bounds x="500" y="560" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Join_di" bpmnElement="Gateway_Join" isMarkerVisible="true">
        <dc:Bounds x="650" y="505" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Return_di" bpmnElement="Task_Return">
        <dc:Bounds x="730" y="490" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="DataStore_Supabase_di" bpmnElement="DataStore_Supabase">
        <dc:Bounds x="525" y="680" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- USER EDGES -->
      <bpmndi:BPMNEdge id="Flow_U1_di" bpmnElement="Flow_U1">
        <di:waypoint x="186" y="135" />
        <di:waypoint x="250" y="135" />
      </bpmndi:BPMNEdge>

      <!-- INTER-APP SEQUENCE FLOWS -->
      <bpmndi:BPMNEdge id="Flow_C1_di" bpmnElement="Flow_C1">
        <di:waypoint x="300" y="380" />
        <di:waypoint x="300" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A1_di" bpmnElement="Flow_A1">
        <di:waypoint x="350" y="530" />
        <di:waypoint x="400" y="530" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A2_di" bpmnElement="Flow_A2">
        <di:waypoint x="425" y="505" />
        <di:waypoint x="425" y="480" />
        <di:waypoint x="500" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A3_di" bpmnElement="Flow_A3">
        <di:waypoint x="425" y="555" />
        <di:waypoint x="425" y="600" />
        <di:waypoint x="500" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A4_di" bpmnElement="Flow_A4">
        <di:waypoint x="600" y="480" />
        <di:waypoint x="675" y="480" />
        <di:waypoint x="675" y="505" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A5_di" bpmnElement="Flow_A5">
        <di:waypoint x="600" y="600" />
        <di:waypoint x="675" y="600" />
        <di:waypoint x="675" y="555" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A6_di" bpmnElement="Flow_A6">
        <di:waypoint x="700" y="530" />
        <di:waypoint x="730" y="530" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C2_di" bpmnElement="Flow_C2">
        <di:waypoint x="830" y="530" />
        <di:waypoint x="900" y="530" />
        <di:waypoint x="900" y="380" />
      </bpmndi:BPMNEdge>

      <!-- MASSAGE / DATA ASSOCIATIONS -->
      <bpmndi:BPMNEdge id="DataAssoc_1_di" bpmnElement="DataAssoc_1">
        <di:waypoint x="550" y="520" />
        <di:waypoint x="550" y="680" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataAssoc_2_di" bpmnElement="DataAssoc_2">
        <di:waypoint x="550" y="640" />
        <di:waypoint x="550" y="680" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_M1_di" bpmnElement="Flow_M1">
        <di:waypoint x="300" y="175" />
        <di:waypoint x="300" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_M2_di" bpmnElement="Flow_M2">
        <di:waypoint x="900" y="300" />
        <di:waypoint x="900" y="153" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
