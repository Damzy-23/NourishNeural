<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_2" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_2">
    <bpmn:participant id="Participant_User" name="Client GUI" processRef="Process_Client" />
    <bpmn:participant id="Participant_Sys" name="ReAct Agent Engine" processRef="Process_Agent" />
    <bpmn:messageFlow id="Flow_M1" sourceRef="Task_Ask" targetRef="Task_Init" />
    <bpmn:messageFlow id="Flow_M2" sourceRef="Task_Respond" targetRef="End_Client" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Client">
    <bpmn:startEvent id="Start_1" name="Type NLP Chat"><bpmn:outgoing>Flow_C1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:task id="Task_Ask" name="POST /api/ai/agent"><bpmn:incoming>Flow_C1</bpmn:incoming></bpmn:task>
    <bpmn:endEvent id="End_Client" name="Render AI Text" />
    <bpmn:sequenceFlow id="Flow_C1" sourceRef="Start_1" targetRef="Task_Ask" />
  </bpmn:process>

  <bpmn:process id="Process_Agent">
    <bpmn:task id="Task_Init" name="Init Tool Context"><bpmn:outgoing>Flow_A1</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_LoopStart" name="Iteration Check"><bpmn:incoming>Flow_A1</bpmn:incoming><bpmn:incoming>Flow_Loop</bpmn:incoming><bpmn:outgoing>Flow_A2</bpmn:outgoing><bpmn:outgoing>Flow_A_Max</bpmn:outgoing></bpmn:exclusiveGateway>
    
    <bpmn:task id="Task_Ollama" name="Query Ollama Engine"><bpmn:incoming>Flow_A2</bpmn:incoming><bpmn:outgoing>Flow_A3</bpmn:outgoing></bpmn:task>
    
    <bpmn:exclusiveGateway id="Gateway_Ollama" name="Ollama Reachable?"><bpmn:incoming>Flow_A3</bpmn:incoming><bpmn:outgoing>Flow_O_Yes</bpmn:outgoing><bpmn:outgoing>Flow_O_No</bpmn:outgoing></bpmn:exclusiveGateway>

    <bpmn:task id="Task_Fallback" name="Format Error / Fallback Response"><bpmn:incoming>Flow_A_Max</bpmn:incoming><bpmn:incoming>Flow_O_No</bpmn:incoming><bpmn:outgoing>Flow_Fall_Join</bpmn:outgoing></bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_IsTool" name="Action Type?"><bpmn:incoming>Flow_O_Yes</bpmn:incoming><bpmn:outgoing>Flow_IsTool</bpmn:outgoing><bpmn:outgoing>Flow_Final</bpmn:outgoing></bpmn:exclusiveGateway>
    
    <bpmn:task id="Task_ExecDB" name="Execute Tool DB Query"><bpmn:incoming>Flow_IsTool</bpmn:incoming><bpmn:outgoing>Flow_Loop</bpmn:outgoing></bpmn:task>
    
    <bpmn:task id="Task_Respond" name="Format Direct Answer"><bpmn:incoming>Flow_Final</bpmn:incoming><bpmn:incoming>Flow_Fall_Join</bpmn:incoming></bpmn:task>
    
    <bpmn:sequenceFlow id="Flow_A1" sourceRef="Task_Init" targetRef="Gateway_LoopStart" />
    <bpmn:sequenceFlow id="Flow_A2" name="&lt;= 5 Iterations" sourceRef="Gateway_LoopStart" targetRef="Task_Ollama" />
    <bpmn:sequenceFlow id="Flow_A_Max" name="&gt; 5 Iterations" sourceRef="Gateway_LoopStart" targetRef="Task_Fallback" />
    
    <bpmn:sequenceFlow id="Flow_A3" sourceRef="Task_Ollama" targetRef="Gateway_Ollama" />
    <bpmn:sequenceFlow id="Flow_O_Yes" name="Yes" sourceRef="Gateway_Ollama" targetRef="Gateway_IsTool" />
    <bpmn:sequenceFlow id="Flow_O_No" name="No (Offline Fallback)" sourceRef="Gateway_Ollama" targetRef="Task_Fallback" />

    <bpmn:sequenceFlow id="Flow_IsTool" name="Tool Call" sourceRef="Gateway_IsTool" targetRef="Task_ExecDB" />
    <bpmn:sequenceFlow id="Flow_Loop" name="Inject Context" sourceRef="Task_ExecDB" targetRef="Gateway_LoopStart" />
    
    <bpmn:sequenceFlow id="Flow_Final" name="Final Answer" sourceRef="Gateway_IsTool" targetRef="Task_Respond" />
    <bpmn:sequenceFlow id="Flow_Fall_Join" sourceRef="Task_Fallback" targetRef="Task_Respond" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_2">
    <bpmndi:BPMNPlane id="BPMNPlane_2" bpmnElement="Collaboration_2">
      <!-- POOLS -->
      <bpmndi:BPMNShape id="Participant_User_di" bpmnElement="Participant_User" isHorizontal="true"><dc:Bounds x="100" y="30" width="950" height="120" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Sys_di" bpmnElement="Participant_Sys" isHorizontal="true"><dc:Bounds x="100" y="170" width="950" height="420" /></bpmndi:BPMNShape>
      
      <!-- USER NODES -->
      <bpmndi:BPMNShape id="Start_1_di" bpmnElement="Start_1"><dc:Bounds x="150" y="82" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Ask_di" bpmnElement="Task_Ask"><dc:Bounds x="250" y="60" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Client_di" bpmnElement="End_Client"><dc:Bounds x="950" y="82" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_C1_di" bpmnElement="Flow_C1"><di:waypoint x="186" y="100" /><di:waypoint x="250" y="100" /></bpmndi:BPMNEdge>

      <!-- SYSTEM NODES -->
      <bpmndi:BPMNShape id="Task_Init_di" bpmnElement="Task_Init"><dc:Bounds x="250" y="330" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LoopStart_di" bpmnElement="Gateway_LoopStart" isMarkerVisible="true"><dc:Bounds x="400" y="345" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Ollama_di" bpmnElement="Task_Ollama"><dc:Bounds x="500" y="330" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Ollama_di" bpmnElement="Gateway_Ollama" isMarkerVisible="true"><dc:Bounds x="650" y="345" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsTool_di" bpmnElement="Gateway_IsTool" isMarkerVisible="true"><dc:Bounds x="750" y="345" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ExecDB_di" bpmnElement="Task_ExecDB"><dc:Bounds x="725" y="450" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Fallback_di" bpmnElement="Task_Fallback"><dc:Bounds x="525" y="200" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Respond_di" bpmnElement="Task_Respond"><dc:Bounds x="880" y="330" width="100" height="80" /></bpmndi:BPMNShape>

      <!-- SEQUENCE EDGES -->
      <bpmndi:BPMNEdge id="Flow_A1_di" bpmnElement="Flow_A1"><di:waypoint x="350" y="370" /><di:waypoint x="400" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A2_di" bpmnElement="Flow_A2"><di:waypoint x="450" y="370" /><di:waypoint x="500" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A_Max_di" bpmnElement="Flow_A_Max"><di:waypoint x="425" y="345" /><di:waypoint x="425" y="240" /><di:waypoint x="525" y="240" /></bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_A3_di" bpmnElement="Flow_A3"><di:waypoint x="600" y="370" /><di:waypoint x="650" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_O_Yes_di" bpmnElement="Flow_O_Yes"><di:waypoint x="700" y="370" /><di:waypoint x="750" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_O_No_di" bpmnElement="Flow_O_No"><di:waypoint x="675" y="345" /><di:waypoint x="675" y="240" /><di:waypoint x="625" y="240" /></bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_IsTool_di" bpmnElement="Flow_IsTool"><di:waypoint x="775" y="395" /><di:waypoint x="775" y="450" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Loop_di" bpmnElement="Flow_Loop"><di:waypoint x="775" y="530" /><di:waypoint x="775" y="560" /><di:waypoint x="425" y="560" /><di:waypoint x="425" y="395" /></bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_Final_di" bpmnElement="Flow_Final"><di:waypoint x="800" y="370" /><di:waypoint x="880" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Fall_Join_di" bpmnElement="Flow_Fall_Join"><di:waypoint x="625" y="240" /><di:waypoint x="850" y="240" /><di:waypoint x="850" y="350" /><di:waypoint x="880" y="350" /></bpmndi:BPMNEdge>

      <!-- MESSAGE FLOWS -->
      <bpmndi:BPMNEdge id="Flow_M1_di" bpmnElement="Flow_M1"><di:waypoint x="300" y="140" /><di:waypoint x="300" y="330" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_M2_di" bpmnElement="Flow_M2"><di:waypoint x="930" y="330" /><di:waypoint x="930" y="230" /><di:waypoint x="968" y="230" /><di:waypoint x="968" y="118" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
